PORT=4000
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_DAYS=30

# Local MongoDB (default). For MongoDB Atlas: replace with your string from Atlas → Connect → Drivers
# Example Atlas: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017

MONGODB_DB_NAME=pixdot
