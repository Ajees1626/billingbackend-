PORT=4000
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_DAYS=30

# Atlas: paste from Atlas → Connect → Drivers, e.g. mongodb+srv://USER:PASS@cluster....mongodb.net/?retryWrites=true&w=majority
# Local (no Atlas): mongodb://127.0.0.1:27017 — MongoDB must be installed and running
MONGODB_URI=mongodb://127.0.0.1:27017

# Database name (collections: users, staff, clients)
MONGODB_DB_NAME=pixdot
